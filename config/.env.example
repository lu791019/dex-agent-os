# Dex Agent OS - 環境變數範本
# 複製此檔為 .env 並填入實際值

# WordPress REST API
WP_URL=https://your-site.com
WP_USERNAME=
WP_APP_PASSWORD=

# Discord Bot (future)
# DISCORD_BOT_TOKEN=
# DISCORD_CHANNEL_ID=

# Notion (future)
# NOTION_TOKEN=
# NOTION_DATABASE_ID=

# Threads API（從 Meta Developer Dashboard「用戶權杖產生器」取得）
THREADS_ACCESS_TOKEN=

# Notion — Podwise 串接（podcast-add --notion）
# 1. https://www.notion.so/my-integrations → 建立 Integration → 複製 Secret
# 2. 在 Podwise 匯出的 Notion database → "..." → "Connect to" → 選 Integration
# 3. 複製 database URL 中的 32 碼 ID
# NOTION_TOKEN=secret_xxxxxxxxxxxx
# NOTION_PODWISE_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Readwise — Podwise 串接（podcast-add --readwise）
# https://readwise.io/access_token → 複製 token
# READWISE_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
