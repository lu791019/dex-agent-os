#!/usr/bin/env bash
# bin/agent — Dex Agent OS CLI 入口
#
# Usage:
#   ./bin/agent journal [YYYY-MM-DD] [--force]
#   ./bin/agent dayflow [YYYY-MM-DD] [--force]
#   ./bin/agent extract [date|all] [--type TYPE] [--force] [--dry-run] [--global]
#   ./bin/agent collect-threads [--limit N] [--since DATE] [--force]
#   ./bin/agent extract-style <channel> [--force]
#   ./bin/agent topic-create [insight-file|--title "..."]
#   ./bin/agent topic-to-thread <topic-slug> [--force]
#   ./bin/agent topic-to-fb <topic-slug> [--force]
#   ./bin/agent topic-to-blog <topic-slug> [--force]
#   ./bin/agent topic-to-short-video <topic-slug> [--force]
#   ./bin/agent film-review --title "..." [--notes "..."] [--rating N] [--force]
#   ./bin/agent youtube-add "URL" [--force] [--date YYYY-MM-DD]
#   ./bin/agent podcast-add --transcript FILE --title "..." [--force]
#   ./bin/agent podcast-add --apple [--latest N]
#   ./bin/agent podcast-add --notion [--latest N] [--all] [--force]
#   ./bin/agent podcast-add --readwise [--latest N] [--all] [--force]
#   ./bin/agent daily-digest [YYYY-MM-DD] [--today] [--send] [--force]
#   ./bin/agent podcast-digest [YYYY-MM-DD] [--pptx] [--force]
#   ./bin/agent weekly-review [YYYY-MM-DD] [--force]
#   ./bin/agent weekly-newsletter [YYYY-MM-DD] [--type TYPE] [--force]
#   ./bin/agent sync
#   ./bin/agent help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"

# 載入環境變數
if [ -f "$ROOT_DIR/.env" ]; then
  set -a
  source "$ROOT_DIR/.env"
  set +a
fi

command="${1:-help}"
shift || true

case "$command" in
  journal)
    python3 "$ROOT_DIR/scripts/generators/daily_journal.py" "$@"
    ;;
  dayflow)
    python3 "$ROOT_DIR/scripts/generators/daily_dayflow_digest.py" "$@"
    ;;
  extract)
    python3 "$ROOT_DIR/scripts/extractors/journal_knowledge_extract.py" "$@"
    ;;
  collect-threads)
    python3 "$ROOT_DIR/scripts/collectors/threads_collector.py" "$@"
    ;;
  extract-style)
    python3 "$ROOT_DIR/scripts/analyzers/extract_style.py" "$@"
    ;;
  topic-create)
    python3 "$ROOT_DIR/scripts/generators/topic_create.py" "$@"
    ;;
  topic-to-thread)
    python3 "$ROOT_DIR/scripts/generators/topic_to_thread.py" "$@"
    ;;
  topic-to-fb)
    python3 "$ROOT_DIR/scripts/generators/topic_to_fb.py" "$@"
    ;;
  topic-to-blog)
    python3 "$ROOT_DIR/scripts/generators/topic_to_blog.py" "$@"
    ;;
  topic-to-short-video)
    python3 "$ROOT_DIR/scripts/generators/topic_to_short_video.py" "$@"
    ;;
  film-review)
    python3 "$ROOT_DIR/scripts/generators/film_review.py" "$@"
    ;;
  youtube-add)
    python3 "$ROOT_DIR/scripts/collectors/youtube_transcript.py" "$@"
    ;;
  learning-note)
    python3 "$ROOT_DIR/scripts/generators/learning_note.py" "$@"
    ;;
  readwise-sync)
    python3 "$ROOT_DIR/scripts/collectors/readwise_sync.py" "$@"
    ;;
  rss-sync)
    python3 "$ROOT_DIR/scripts/collectors/rss_sync.py" "$@"
    ;;
  anybox-sync)
    python3 "$ROOT_DIR/scripts/collectors/anybox_sync.py" "$@"
    ;;
  gmail-sync)
    python3 "$ROOT_DIR/scripts/collectors/gmail_sync.py" "$@"
    ;;
  daily-digest)
    python3 "$ROOT_DIR/scripts/generators/daily_digest.py" "$@"
    ;;
  podcast-add)
    python3 "$ROOT_DIR/scripts/collectors/podcast_transcript.py" "$@"
    ;;
  podcast-digest)
    python3 "$ROOT_DIR/scripts/generators/podcast_digest.py" "$@"
    ;;
  weekly-review)
    python3 "$ROOT_DIR/scripts/generators/weekly_review.py" "$@"
    ;;
  weekly-newsletter)
    python3 "$ROOT_DIR/scripts/generators/weekly_newsletter.py" "$@"
    ;;
  classroom-sync)
    python3 "$ROOT_DIR/scripts/collectors/classroom_sync.py" "$@"
    ;;
  sync)
    "$ROOT_DIR/bin/sync" "$@"
    ;;
  sync-all)
    echo "[sync-all] 開始批次匯入..."
    python3 "$ROOT_DIR/scripts/collectors/readwise_sync.py" --reader --latest 10 "$@"
    python3 "$ROOT_DIR/scripts/collectors/rss_sync.py" --latest 10 "$@"
    python3 "$ROOT_DIR/scripts/collectors/anybox_sync.py" --latest 10 "$@"
    python3 "$ROOT_DIR/scripts/collectors/gmail_sync.py" --latest 10 "$@"
    echo "[sync-all] 批次匯入完成"
    ;;
  help|--help|-h)
    cat <<EOF
Dex Agent OS — CLI

Usage:
  ./bin/agent <command> [options]

Commands:
  journal [YYYY-MM-DD] [--force]                          產出每日精煉日記（L2）
  dayflow [YYYY-MM-DD] [--force]                          產出 Dayflow 活動摘要日記
  extract [date|all] [--type TYPE] [--force] [--dry-run] [--global]
                                                          萃取日記知識（學習/反思/靈感）
  collect-threads [--limit N] [--since DATE] [--force]    自動抓取 Threads 文章
  extract-style <channel> [--force]                       提取風格 DNA
  topic-create [insight-file|--title "..."]               從 insight 建立主題
  topic-to-thread <topic-slug> [--force]                  主題 → Threads 草稿
  topic-to-fb <topic-slug> [--force]                     主題 → Facebook 貼文草稿
  topic-to-blog <topic-slug> [--force]                   主題 → 部落格文章草稿
  topic-to-short-video <topic-slug> [--force]            主題 → 短影音腳本
  film-review --title "..." [--notes "..."] [--rating N] 電影 → 影評
  learning-note --url URL [--type TYPE] [--force]         URL → 學習筆記
  learning-note --file PATH --title "..." [--type TYPE]  本地檔案 → 學習筆記
  learning-note --readwise [--reader] [--latest N]       Readwise → 學習筆記
  learning-note --rss FEED [--latest N]                  RSS → 學習筆記
  learning-note --anybox [--starred] [--latest N]        Anybox → 學習筆記
  readwise-sync [--category CAT] [--latest N] [--force]  Readwise highlights 批次匯入
  readwise-sync --reader [--latest N] [--force]          Readwise Reader 批次匯入
  rss-sync [--feed URL] [--opml FILE] [--latest N]       RSS 批次匯入
  anybox-sync [--tag TAG] [--starred] [--latest N]       Anybox 書籤批次匯入
  gmail-sync [--label X] [--from ADDR] [--latest N]      Gmail 電子報批次匯入
  youtube-add "URL" [--force] [--date YYYY-MM-DD]         YouTube 字幕 → 學習筆記
  podcast-add --transcript FILE --title "..." [--force]   手動逐字稿 → episode 筆記
  podcast-add --apple [--latest N]                        Apple Podcast 快取匯入
  podcast-add --notion [--latest N] [--all] [--force]     Notion Podwise DB 匯入
  podcast-add --readwise [--latest N] [--all] [--force]   Readwise podcast highlights 匯入
  daily-digest [YYYY-MM-DD] [--today] [--send] [--force] 每日學習消化報告
  podcast-digest [YYYY-MM-DD] [--pptx] [--force]         週度消化報告（合併 YT + Podcast）
  weekly-review [YYYY-MM-DD] [--force]                    產出個人週回顧
  weekly-newsletter [YYYY-MM-DD] [--type TYPE] [--force]  產出電子報草稿
  sync                                                    跨平台同步 canonical → IDE
  sync-all [--latest N] [--force]                         一鍵批次匯入（readwise+rss+anybox+gmail）
  help                                                    顯示此說明

Examples:
  ./bin/agent journal               產出今天的精煉日記
  ./bin/agent journal 2026-02-07    產出指定日期的精煉日記
  ./bin/agent dayflow               產出今天的 Dayflow 活動摘要
  ./bin/agent extract               萃取所有日記的知識
  ./bin/agent extract --global      同時更新全域 ~/CLAUDE.md
  ./bin/agent collect-threads       抓取你的 Threads 文章（需先設定 Meta App）
  ./bin/agent extract-style threads 從範例提取 Threads 風格 DNA
  ./bin/agent topic-create          列出可用 insights
  ./bin/agent topic-create 510_Insights/xxx.md    從 insight 建立主題
  ./bin/agent topic-to-thread slug  主題 → Threads 草稿
  ./bin/agent topic-to-fb slug     主題 → Facebook 貼文草稿
  ./bin/agent topic-to-blog slug   主題 → 部落格文章草稿
  ./bin/agent topic-to-short-video slug  主題 → 短影音腳本
  ./bin/agent film-review --title "電影名" --notes "觀影筆記" --rating 8  產出影評
  ./bin/agent learning-note --url "https://..." 網頁文章 → 學習筆記
  ./bin/agent learning-note --readwise --reader --latest 3  Reader 最新 3 篇 → 學習筆記
  ./bin/agent readwise-sync --reader --latest 5  匯入 Reader 最新 5 篇原文
  ./bin/agent rss-sync --feed "https://jvns.ca/atom.xml" --latest 3  匯入 RSS 最新 3 篇
  ./bin/agent anybox-sync --starred --latest 3  匯入星號書籤最新 3 筆
  ./bin/agent gmail-sync --latest 5  列出最近 5 封電子報
  ./bin/agent gmail-sync --from "newsletter@substack.com" --latest 3 --force  匯入指定寄件者
  ./bin/agent youtube-add "URL"     YouTube 影片 → 結構化學習筆記
  ./bin/agent podcast-add --transcript file.txt --title "..." 手動逐字稿
  ./bin/agent podcast-add --apple   匯入 Apple Podcast 快取
  ./bin/agent podcast-add --notion --latest 5  從 Notion Podwise 匯入
  ./bin/agent podcast-add --readwise --latest 5  從 Readwise 匯入
  ./bin/agent daily-digest           產出昨日的學習消化報告
  ./bin/agent daily-digest --today   產出今天的學習消化報告
  ./bin/agent daily-digest --send    同時建立 Google Doc + 寄 Gmail
  ./bin/agent podcast-digest        產出本週 Podcast 消化報告
  ./bin/agent podcast-digest --pptx 同時產出簡報
  ./bin/agent weekly-review         產出本週的週回顧
  ./bin/agent weekly-newsletter     產出本週的電子報草稿
  ./bin/agent sync-all              一鍵匯入所有來源最新 10 筆
  ./bin/agent sync-all --latest 5   每個來源最新 5 筆
  ./bin/agent weekly-newsletter --type deep-dive  指定電子報類型
  ./bin/agent sync                  同步規則到所有 IDE
EOF
    ;;
  *)
    echo "Unknown command: $command"
    echo "Run './bin/agent help' for usage."
    exit 1
    ;;
esac
