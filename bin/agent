#!/usr/bin/env bash
# bin/agent — Dex Agent OS CLI 入口
#
# Usage:
#   ./bin/agent journal [YYYY-MM-DD] [--force]
#   ./bin/agent sync
#   ./bin/agent help

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT_DIR="$(dirname "$SCRIPT_DIR")"

command="${1:-help}"
shift || true

case "$command" in
  journal)
    python3 "$ROOT_DIR/scripts/generators/daily_journal.py" "$@"
    ;;
  sync)
    "$ROOT_DIR/bin/sync" "$@"
    ;;
  help|--help|-h)
    cat <<EOF
Dex Agent OS — CLI

Usage:
  ./bin/agent <command> [options]

Commands:
  journal [YYYY-MM-DD] [--force]   產出每日精煉日記（L2）
  sync                              跨平台同步 canonical → IDE
  help                              顯示此說明

Examples:
  ./bin/agent journal               產出今天的精煉日記
  ./bin/agent journal 2026-02-07    產出指定日期的精煉日記
  ./bin/agent journal --force       強制覆蓋已存在的日記
  ./bin/agent sync                  同步規則到所有 IDE
EOF
    ;;
  *)
    echo "Unknown command: $command"
    echo "Run './bin/agent help' for usage."
    exit 1
    ;;
esac
